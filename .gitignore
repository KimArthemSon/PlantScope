# ======================
# Django Migrations (CRITICAL - TRACK THESE!)
# ======================
# Ignore the __pycache__ folders inside migrations
**/migrations/__pycache__/

# But TRACK the actual migration .py files (this is required for Render deployment!)
!*/migrations/*.py
!*/migrations/__init__.py

